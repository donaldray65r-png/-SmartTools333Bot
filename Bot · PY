 import os
import logging
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    Application,
    CommandHandler,
    MessageHandler,
    CallbackQueryHandler,
    ContextTypes,
    filters,
)
from telegram.error import TelegramError

# ---------- Logging ----------
logging.basicConfig(
    format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    level=logging.INFO,
)
logger = logging.getLogger(__name__)

# ---------- Config ----------
BOT_TOKEN = os.environ.get("BOT_TOKEN")

# Tracks which tool a user has selected, so we know how to handle their next text message
user_mode = {}


# ---------- UI ----------
def main_menu_keyboard():
    keyboard = [
        [InlineKeyboardButton("📝 Word Counter", callback_data="wordcounter")],
        # Add more tools here as buttons later, e.g.:
        # [InlineKeyboardButton("🖼 Image Generator", callback_data="imagegen")],
    ]
    return InlineKeyboardMarkup(keyboard)


# ---------- Handlers ----------
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        await update.message.reply_text(
            "👋 Welcome to SmartTools Bot!\n\nChoose a tool below:",
            reply_markup=main_menu_keyboard(),
        )
    except TelegramError as e:
        logger.error(f"Error in /start: {e}")


async def help_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        await update.message.reply_text(
            "Available commands:\n"
            "/start - Show welcome message and menu\n"
            "/menu - Show tools menu\n"
            "/help - Show this message"
        )
    except TelegramError as e:
        logger.error(f"Error in /help: {e}")


async def menu(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        await update.message.reply_text(
            "Choose a tool:", reply_markup=main_menu_keyboard()
        )
    except TelegramError as e:
        logger.error(f"Error in /menu: {e}")


async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    try:
        await query.answer()
        user_id = query.from_user.id

        if query.data == "wordcounter":
            user_mode[user_id] = "wordcounter"
            await query.edit_message_text(
                "📝 Word Counter selected.\n\n"
                "Send me any text and I'll count the words and characters.\n\n"
                "Use /menu anytime to switch tools."
            )
    except TelegramError as e:
        logger.error(f"Error in button_handler: {e}")


async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        user_id = update.effective_user.id
        mode = user_mode.get(user_id)
        text = update.message.text

        if not text:
            return

        if mode == "wordcounter":
            words = len(text.split())
            chars = len(text)
            chars_no_spaces = len(text.replace(" ", ""))
            await update.message.reply_text(
                f"📊 Results:\n\n"
                f"Words: {words}\n"
                f"Characters (with spaces): {chars}\n"
                f"Characters (no spaces): {chars_no_spaces}"
            )
        else:
            await update.message.reply_text(
                "Please choose a tool first using /menu"
            )
    except TelegramError as e:
        logger.error(f"Error in handle_text: {e}")
    except Exception as e:
        logger.error(f"Unexpected error in handle_text: {e}")


async def error_handler(update: object, context: ContextTypes.DEFAULT_TYPE):
    """Log any unhandled errors instead of letting the bot crash."""
    logger.error(f"Update {update} caused error: {context.error}")


# ---------- Main ----------
def main():
    if not BOT_TOKEN:
        logger.critical(
            "BOT_TOKEN environment variable is not set. "
            "Set it in Railway's Variables tab before deploying."
        )
        raise SystemExit(1)

    app = Application.builder().token(BOT_TOKEN).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("help", help_command))
    app.add_handler(CommandHandler("menu", menu))
    app.add_handler(CallbackQueryHandler(button_handler))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))

    app.add_error_handler(error_handler)

    logger.info("Bot starting with polling...")
    app.run_polling(
        allowed_updates=Update.ALL_TYPES,
        drop_pending_updates=True,
    )


if __name__ == "__main__":
    main()
